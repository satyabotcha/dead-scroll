{
  "manifest_version": 3,
  "name": "Monk Mode",
  "version": "0.1.0",
  "description": "Removes distracting social feeds, starting with YouTube.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Monk Mode",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    }
  ]
}
