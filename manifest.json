{
  "manifest_version": 3,
  "name": "Monk Mode",
  "version": "0.1.0",
  "description": "Removes distracting social feeds while preserving intentional use.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Monk Mode",
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/universe_background.png"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
