{
  "manifest_version": 3,
  "name": "Monk Mode",
  "version": "0.1.0",
  "description": "Removes distracting social feeds while preserving intentional use.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon_focused_16.png",
    "32": "assets/icon_focused_32.png",
    "48": "assets/icon_focused_48.png",
    "128": "assets/icon_focused_128.png"
  },
  "action": {
    "default_title": "Monk Mode",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon_focused_16.png",
      "32": "assets/icon_focused_32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/universe_background.png"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["content/youtube-early.css"],
      "js": ["content/youtube-dark.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
