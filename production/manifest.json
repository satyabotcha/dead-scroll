{
  "manifest_version": 3,
  "name": "Dead Scroll",
  "version": "0.1.1",
  "description": "Kill YouTube distractions",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon_focused_16.png",
    "32": "assets/icon_focused_32.png",
    "48": "assets/icon_focused_48.png",
    "128": "assets/icon_focused_128.png"
  },
  "action": {
    "default_title": "Dead Scroll",
    "default_icon": {
      "16": "assets/icon_focused_16.png",
      "32": "assets/icon_focused_32.png",
      "48": "assets/icon_focused_48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/backgrounds/*.webp"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["content/youtube-early.css"],
      "js": ["content/youtube-dark.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content/youtube.js"],
      "run_at": "document_idle"
    }
  ]
}
