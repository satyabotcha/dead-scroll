{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noEmitOnError": true,
    "rootDir": "src",
    "outDir": "production",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"]
}
